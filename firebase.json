{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git/**",
      "package.json",
      "package-lock.json",
      "pnpm-lock.yaml",
      "playwright.config.js",
      "tests/**",
      "*.md",
      "docs/**",
      ".github/**",
      "scripts/**",
      "backend/**",
      "shared/**",
      "contracts/**",
      "database/**",
      "dist/**",
      ".cursor/**",
      "tsconfig.json",
      "vite.config.ts",
      "vite-env.d.ts",
      "docker-compose.yml",
      "firestore.rules",
      "storage.rules",
      "firestore.indexes.json"
    ],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  },
  "emulators": {
    "singleProjectMode": true,
    "auth": { "port": 9099, "host": "127.0.0.1" },
    "firestore": { "port": 8080, "host": "127.0.0.1" },
    "storage": { "port": 9199, "host": "127.0.0.1" },
    "hosting": { "port": 5000, "host": "127.0.0.1" },
    "ui": { "enabled": true, "host": "127.0.0.1", "port": 4000 }
  }
}
