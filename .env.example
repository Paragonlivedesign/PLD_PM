# =============================================================================
# PLD_PM — local development (copy this file to `.env` at the REPO ROOT)
# =============================================================================
# The API loads `.env` from the project root (same folder as package.json), not
# from `backend/`. After editing, restart: `npm run dev` (or `npm run dev -w backend`).
#
# PostgreSQL: use native install or Docker. Default dev connection below matches
# `docker-compose.yml` and `database/bootstrap-windows-pld.sql`. See database/README.md
# to create user `pld`, password `pld`, database `pld_dev` on Windows without Docker.
#
# Then run once (empty or new database only): `npm run db:migrate`
# Optional: `npm run db:seed` — demo clients/venues + dev owner user (see docs/bootstrap-dev-identity.md)
#
# OWNER_EMAIL or PLD_DEV_OWNER_EMAIL — email for the seeded owner on tenant `demo` (password `pld` in dev seed only).
# OWNER_EMAIL=cody@paragonlivedesign.com
#
# Web sign-in (after migrations): tenant `demo`, admin@demo.local / password — also testtenant@testtenant.com / pld on tenant `test` (migration 009)
# =============================================================================

NODE_ENV=development
PORT=3000

# Required for API + auth (login, JWT). Must match your Postgres role + DB name.
DATABASE_URL=postgresql://pld:pld@localhost:5432/pld_dev

# Optional: Redis — when set, auth module uses it for the short-lived **permission list** cache
# (shared invalidation across API instances). If unset or unreachable, falls back to in-memory cache.
REDIS_URL=redis://localhost:6379

# Browser origins allowed to call the API (comma-separated). Add your Vite URL.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5000,http://localhost:5000

# Required for JWT sign-in / refresh unless you use RSA keys below.
# Omit JWT_PRIVATE_KEY / JWT_PUBLIC_KEY → access tokens use HS256 with this secret (fine for dev).
JWT_SECRET=change-me-to-a-long-random-string-for-dev

# Public self-signup: POST /api/v1/auth/register (tenant_slug + email + password → viewer role).
# Set to false in production if you only use invitations / seeded users.
# AUTH_ALLOW_PUBLIC_REGISTER=true

# Comma-separated emails allowed to call GET /api/v1/platform/tenants (master admin UI).
# Must match the signed-in user exactly (case-insensitive). Rotate in production.
# PLD_PLATFORM_ADMIN_EMAILS=Cody@paragonlivedesign.com

# Optional — production-style RS256 (PEM). When both are set, HS256 / JWT_SECRET is not used for access tokens.
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Destructive: POST /api/v1/tenant/reset-data (Settings → Danger Zone) is allowed when NODE_ENV is not production.
# In production, must set explicitly:
# PLD_ALLOW_TENANT_DATA_RESET=1

# POST /api/v1/tenant/seed-demo (top bar “Seed demo” on localhost) — same catalog as scripts/seed-demo-catalog.mjs / npm run db:seed.
# Allowed when NODE_ENV is not production.
# PLD_ALLOW_TENANT_DEMO_SEED=1

# --- Optional toggles (see backend middleware) ---
# REQUIRED for production/staging: lock API to Bearer JWT only (no X-Tenant-Id / X-User-Id shortcut).
# PLD_DEV_AUTH_HEADERS=false
# When unset, default allows dev headers (local only). Also gates WebSocket "dev" token auth (see collaboration.contract.md).
# PLD_ALLOW_DEFAULT_CONTEXT=0 — do not fall back to default tenant/user UUIDs when headers missing.
# PLD_SKIP_TENANT_RESOLUTION=1 — skip tenants-table check (tests only; not for production).
# PLD_RATE_LIMIT_DISABLED=1
# PLD_RATE_LIMIT_MAX=2000 (invalid/empty values fall back to 2000)
# PLD_RATE_LIMIT_WINDOW_MS=60000
# Local browser to 127.0.0.1 / ::1 is not rate-limited. Remote clients still use the limits above.

# --- Truck routes + venue maps (optional) ---
# GOOGLE_MAPS_API_KEY — server-side Routes API v2 (traffic-aware ETA), venue POST /venues/resolve-maps-link (geocoding),
# and GET /venues/:id/banner-preview (Static Maps / Street View proxy). Same key as GOOGLE_ROUTES_API_KEY if you use one variable.
# PLD_PUBLIC_BASE_URL=https://pm.example.com — full URLs for driver share links (otherwise path-only).
# PLD_ROUTE_DELAY_NOTIFY_MINUTES=15 — notify event owner when compute-route pushes ETA vs previous by ≥ this many minutes.

# --- Documents module (optional) ---
# DOCUMENTS_STORAGE_ROOT=./data/documents
# DOCUMENT_DOWNLOAD_SECRET=change-me-in-production
# PUBLIC_API_BASE=http://127.0.0.1:3000

# --- Production example (do not use for local dev) ---
# CORS_ORIGIN=https://pm.paragonlivedesign.com
